<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="using:KursMVVM.ViewModels"
			 xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="KursMVVM.GraphPageView"
			 x:DataType="vm:GraphPageViewModel">
	<UserControl.DataContext>
		<vm:GraphPageViewModel/>
	</UserControl.DataContext>
	<StackPanel Orientation="Horizontal">
		<TabControl Margin="5">
			<TabItem Header="План" >
				<lvc:CartesianChart Series="{Binding SeriesCollection}"/>
			</TabItem>
			<TabItem Header="Доля">
				<TextBlock Margin="5">This is tab 2 content</TextBlock>
			</TabItem>
			<TabItem Header="Динамика">
				<TextBlock Margin="5">This is tab 3 content</TextBlock>
			</TabItem>
			<TabItem Header="Заказы">
				<TextBlock Margin="5">This is tab 4 content</TextBlock>
			</TabItem>
		</TabControl>
	</StackPanel>
</UserControl>
