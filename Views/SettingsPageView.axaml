<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:KursMVVM.ViewModels"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="KursMVVM.SettingsPageView"
			 x:DataType="vm:ProductsPageViewModel">
	<Design.DataContext>
		<vm:ProductsPageViewModel/>
	</Design.DataContext>
	<StackPanel Margin="20" Spacing="15">
		<TextBlock Text="Настройки"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

		<StackPanel Orientation="Horizontal" Spacing="10">
			<TextBlock Text="Имя пользователя:"
                       VerticalAlignment="Center"
                       FontSize="14"/>
			<TextBox Text="{Binding UserName}"
                     Width="200"
                     Watermark="Введите имя"/>
		</StackPanel>

		<StackPanel Orientation="Horizontal" Spacing="10">
			<TextBlock Text="Тёмная тема:"
                       VerticalAlignment="Center"
                       FontSize="14"/>
			<CheckBox IsChecked="{Binding IsDarkTheme}"/>
		</StackPanel>
	</StackPanel>
</UserControl>
