<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
        x:Class="KursMVVM.ClientWindow"
        xmlns:view="using:KursMVVM"
		Title="ClientWindow"
		Width="400" Height="500"
		x:DataType="view:ClientWindow">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
			<RowDefinition/>
		</Grid.RowDefinitions>
		<TextBox Grid.Row="0" Text="{Binding Client.FirstName}"
				 Margin="10 20" PlaceholderText="»м€"/>
		<TextBox Grid.Row="1" Text="{Binding Client.LastName}"
				 Margin="10 20" PlaceholderText="ќтчество"/>
		<TextBox Grid.Row="2" Text="{Binding Client.Surname}"
				 Margin="10 20" PlaceholderText="‘амили€"/>
		<TextBox Grid.Row="3" Text="{Binding Client.Address}"
				 Margin="10 20" PlaceholderText="јдрес"/>
		<TextBox Grid.Row="4" Text="{Binding Client.Phone}"
				 Margin="10 20" PlaceholderText="“елефон"/>
		<TextBox Grid.Row="5" Text="{Binding Client.NumberDogovor}"
				 Margin="10 20" PlaceholderText="Ќомер договора"/>
		<DatePicker Grid.Row="6" SelectedDate="{Binding Client.DataDogovor}"
					Margin="10 20"/>
		<Grid Grid.Row="7">
			<Grid.ColumnDefinitions>
				<ColumnDefinition/>
				<ColumnDefinition/>
			</Grid.ColumnDefinitions>
			<Button Grid.Column="0" Content="Save" HorizontalAlignment="Center"
					VerticalAlignment="Center"
					Click="Save_Click"/>
			<Button Grid.Column="1" Content="Cancel"
					HorizontalAlignment="Center"
					Click="Cancel_Click"
					VerticalAlignment="Center"/>
		</Grid>
	</Grid>
</Window>
